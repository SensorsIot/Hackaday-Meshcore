{
    "name": "Hackaday - PlatformIO Development",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "workspaceFolder": "/workspaces/Hackaday",
    "customizations": {
        "vscode": {
            "extensions": [
                "platformio.platformio-ide",
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "C_Cpp.default.compilerPath": "/usr/bin/gcc"
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/sshd:1": {
            "version": "latest"
        }
    },
    "runArgs": [
        "--name", "hackaday",
        "--privileged",
        "-v", "/dev:/dev",
        "-p", "2471:2222"
    ],
    "remoteUser": "dev",
    "containerEnv": {
        "PLATFORMIO_CORE_DIR": "/home/dev/.platformio",
        "INFLUXDB_TOKEN": "${localEnv:INFLUXDB_TOKEN}",
        "INFLUXDB_URL": "${localEnv:INFLUXDB_URL}",
        "INFLUXDB_ORG": "${localEnv:INFLUXDB_ORG}",
        "HA_TOKEN": "${localEnv:HA_TOKEN}",
        "HA_TOKEN_NODERED": "${localEnv:HA_TOKEN_NODERED}",
        "HA_URL": "${localEnv:HA_URL}",
        "GRAFANA_URL": "${localEnv:GRAFANA_URL}",
        "GRAFANA_USER": "${localEnv:GRAFANA_USER}",
        "GRAFANA_PASSWORD": "${localEnv:GRAFANA_PASSWORD}",
        "TELEGRAM_BOT_TOKEN": "${localEnv:TELEGRAM_BOT_TOKEN}",
        "GH_TOKEN": "${localEnv:GH_TOKEN}",
        "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
        "SMART_USER": "${localEnv:SMART_USER}",
        "SMART_PASSWORD": "${localEnv:SMART_PASSWORD}",
        "ALARM_BOT_TOKEN": "${localEnv:ALARM_BOT_TOKEN}",
        "ALARM_CHAT_ID": "${localEnv:ALARM_CHAT_ID}"
    },
    "mounts": [
        "source=${localEnv:HOME}/.ssh/authorized_keys,target=/home/dev/.ssh/authorized_keys,type=bind,readonly",
        "source=${localEnv:HOME}/.ssh/id_ed25519,target=/home/dev/.ssh/id_ed25519,type=bind,readonly",
        "source=${localEnv:HOME}/.git-credentials,target=/home/dev/.git-credentials,type=bind,readonly",
        "source=${localWorkspaceFolder}/.claude-data,target=/home/dev/.claude-data,type=bind"
    ],
    "postCreateCommand": "git config --global credential.helper store && git config --global core.sshCommand 'ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null' && (git clone https://github.com/SensorsIot/claude.git ~/.claude 2>&1 || (cd ~/.claude && git pull)) && mkdir -p ~/.claude-data/projects && ln -sf ~/.claude-data/.credentials.json ~/.claude/.credentials.json && ln -sf ~/.claude-data/history.jsonl ~/.claude/history.jsonl && rm -rf ~/.claude/projects && ln -sf ~/.claude-data/projects ~/.claude/projects && ln -sf ~/.claude-data/.claude.json ~/.claude.json && sudo npm install -g @anthropic-ai/claude-code && echo 'alias superclaude=\"claude --dangerously-skip-permissions\"' >> ~/.bashrc && mkdir -p ~/.githooks && cp ~/.claude/githooks/pre-push ~/.githooks/pre-push && chmod +x ~/.githooks/pre-push && git config --global core.hooksPath ~/.githooks"
}
